# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS build

WORKDIR /app

# Függőségek (cache layer)
COPY thinkai-voice-agent/eaisydesk-frontend/package*.json ./
RUN npm ci

# Forráskód + .env (VITE_ változók build-time beleégetése)
COPY thinkai-voice-agent/eaisydesk-frontend/ ./

RUN npx vite build

# ── Stage 2: Serve ────────────────────────────────────────────────────────────
FROM nginx:alpine

# dist/ → /usr/share/nginx/html/admin/
# (Vite base: '/admin/' miatt az assetek /admin/assets/... útvonalon lesznek)
COPY --from=build /app/dist /usr/share/nginx/html/admin

COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -qO- http://localhost/admin/ || exit 1
