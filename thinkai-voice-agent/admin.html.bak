       [JS-FILE: admin-core.js] MAIN SCRIPT BLOCK START (line ~10257)
       Contains ALL core JS: globals, auth, dark mode, sidebar, navigation,
       analytics, interactions, kanban, calendar, urgent cases, greeting,
       settings/tudastar, praxis info, upload, szabalyok.
       SPLIT TARGET: admin-core.js, admin-analytics.js, admin-interactions.js,
       admin-kanban.js, admin-calendar.js, admin-settings.js, admin-urgent.js
       GLOBALS EXPOSED: API, authToken, currentUser, authFetch(), showToast(),
       showPage(), toggleDarkMode(), etc.

  <!-- ===================================================================
       [JS-FILE: admin-customers.js] SCRIPT BLOCK START (line ~16067)
       Customer Center JS: security modal, create user, sidebar password,
       client list, customer view switcher, conversation log parser,
       client details, tag system, clinics/doctors/services/triage CRUD,
       approvals, column visibility, DOMContentLoaded init
       GLOBALS EXPOSED: openSecurityPasswordModal(), loadClients(),
       openClientDetails(), loadApprovals(), switchApprovalTab(), etc.

  <!-- Alert Details Modal HTML -->
  <div id="alert-details-modal"
    style="display:none; position:fixed; top:0;left:0;right:0;bottom:0; background:rgba(0,0,0,0.6); z-index:9999; align-items:center; justify-content:center;">
    <div class="login-card"
      style="width:800px; max-width:95vw; max-height:85vh; padding:0; overflow:hidden; border-radius:16px; border:none; box-shadow: 0 20px 40px rgba(0,0,0,0.2); display:flex; flex-direction:column;">
      <!-- Header -->
      <div
        style="background: linear-gradient(to right, #fef2f2, #fee2e2); padding: 20px 24px; border-bottom: 1px solid rgba(0,0,0,0.05);">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div>
            <h3 id="alert-modal-title"
              style="margin:0; color:#b91c1c; font-size:18px; font-weight:700;">Részletek: ...</h3>
          </div>
          <button onclick="document.getElementById('alert-details-modal').style.display='none'"
            style="background:transparent; border:none; color:rgba(0,0,0,0.4); font-size:24px; cursor:pointer; line-height:1;">&times;</button>
        </div>
      </div>
      <!-- Content -->
      <div style="padding: 24px; overflow-y:auto; flex:1; background:var(--bg2);">
        <div class="table-card" style="margin:0; box-shadow:none; border:1px solid rgba(0,0,0,0.05);">
          <table class="data-table" style="margin:0;">
            <thead id="alert-modal-thead">
              <tr>
                <th>Dátum</th>
                <th>Csatorna</th>
                <th>Név / Téma</th>
                <th>Részlet / Státusz</th>
              </tr>
            </thead>
            <tbody id="alert-modal-tbody">
              <tr><td colspan="4" style="text-align:center;">Betöltés...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

          


          


<!-- ===================================================================
     [JS-FILE: admin-customers.js] ADDENDUM -- forceOpenProfile
     window.forceOpenProfile() -- dynamically creates edit profile modal
     DEPENDS ON: window.currentClientDataForLog, window.saveClientProfile

<!-- ===================================================================
     [JS-FILE: admin-outbound.js] SCRIPT BLOCK START (line ~18425)
     Outbound campaigns: CRUD, wizard, client picker, schedule,
     analytics charts, rich text editors, campaign preview
     GLOBALS EXPOSED: loadCampaigns(), saveCampaign(), deleteCampaign(),
     openCampaignModal(), goToClientListForCampaign(), etc.
     DEPENDS ON: authFetch(), showToast(), showPage() from admin-core.js

<!-- [HTML-SECTION: floating-elements] -- Floating campaign client picker bar (outbound.css) -->
<div class="camp-float-bar" id="camp-float-bar">
  <div class="camp-float-info">
    <div class="camp-float-icon">
      <svg fill="none" stroke="#1ceee0" stroke-width="2" viewBox="0 0 24 24" style="width:20px; height:20px;"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
    </div>
    <div>
      <div class="camp-float-title">Ügyfelek kiválasztása kampányhoz</div>
      <div class="camp-float-subtitle">Jelöld ki az ügyfeleket, majd kattints a "Vissza" gombra</div>
    </div>
  </div>
  <div class="camp-float-actions">
    <div style="display:flex; align-items:center; gap:8px;">
      <span style="font-size:12px; color:rgba(255,255,255,0.5);">Kijelölve:</span>
      <span class="camp-float-count" id="camp-float-count">0</span>
    </div>
    <button class="camp-float-cancel" onclick="cancelCampClientPick()">Mégsem</button>
    <button class="camp-float-confirm" onclick="confirmCampClientPick()">
      <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="width:14px; height:14px;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"></path></svg>
      Vissza a kampányhoz
    </button>
  </div>
</div>

  <!-- JS Modules (extracted from inline scripts) -->
  <script src="js/admin-core.js"></script>
  <script src="js/admin-analytics.js"></script>
  <script src="js/admin-interactions.js"></script>
  <script src="js/admin-calendar.js"></script>
  <script src="js/admin-kanban.js"></script>
  <script src="js/admin-urgent.js"></script>
  <script src="js/admin-settings.js"></script>
  <script src="js/admin-customers.js"></script>
  <script src="js/admin-outbound.js"></script>

